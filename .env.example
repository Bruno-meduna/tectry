# Resend — envio do formulário de cotação
# Crie a chave em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Remetente verificado no Resend (domínio tecjato.com.br)
# Ex.: "Tecjato <site@tecjato.com.br>"
QUOTE_FROM_EMAIL="Tecjato <site@tecjato.com.br>"

# Destino interno das cotações
QUOTE_TO_EMAIL=vendas@tecjato.com.br

# URL pública do site (usada em metadata/OG/sitemap)
NEXT_PUBLIC_SITE_URL=https://www.tecjato.com.br
